---
import '@/styles/global.css'
import { TooltipProviderWrapper } from '@/components/web/TooltipProviderWrapper'
import { ThemeSwitch } from '@/components/web/ThemeSwitch'
import { siGithub } from 'simple-icons'
import { IconLoader } from '@/components/web/IconLoader'

const SITE_URL = 'https://humantodo.dev'

interface Meta {
  title?: string
  description?: string
  image?: string
}

interface Props extends Meta {
  frontmatter?: Meta
}

const props = (Astro.props as Props).frontmatter ?? (Astro.props as Meta)
const title = props.title ?? 'HUMANTODO'
const description = props.description ?? 'HUMANTODO is the IKEA effect, but for coding in the AI era.'
const image = props.image ?? '/ikea_effect.png'

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href
const imageUrl = new URL(image, SITE_URL).href
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:site_name" content="HUMANTODO" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <script is:inline>
      ;(() => {
        const storageKey = 'theme'
        const mediaQuery = '(prefers-color-scheme: dark)'

        const getThemePreference = () => {
          const storedTheme = window.localStorage.getItem(storageKey)

          if (storedTheme === 'system' || storedTheme === 'light' || storedTheme === 'dark') {
            return storedTheme
          }

          return 'system'
        }

        const getTheme = () => {
          const themePreference = getThemePreference()
          if (themePreference === 'system') {
            return window.matchMedia(mediaQuery).matches ? 'dark' : 'light'
          }

          return themePreference
        }

        const applyTheme = () => {
          const themePreference = getThemePreference()
          const theme = getTheme()
          const root = document.documentElement
          const isDark = theme === 'dark'

          root.classList.toggle('dark', isDark)
          root.dataset.theme = theme
          root.dataset.themePreference = themePreference
          root.style.colorScheme = theme
        }

        applyTheme()
        document.addEventListener('astro:after-swap', applyTheme)
      })()
    </script>
    <script src="https://cdn.usefathom.com/script.js" data-site="QWPMPCWD" defer></script>
  </head>
  <body>
    <TooltipProviderWrapper client:load>
      <nav class="mx-auto flex max-w-3xl items-center justify-between p-3">
        <a href="/">
          <img src="/logo.png" alt="HUMANTODO logo" class="h-8 w-auto" />
        </a>

        <div class="flex items-center gap-2">
          <ThemeSwitch client:load />
          <a href="https://github.com/humantodo/humantodo" target="_blank" rel="noopener noreferrer">
            <IconLoader icon={siGithub} size={22} />
          </a>
        </div>
      </nav>

      <div class="content-wrapper mx-auto flex min-h-svh max-w-3xl min-w-0 flex-col gap-5 p-5 leading-loose">
        <slot />
      </div>

      <footer class="my-10">
        <div class="flex w-full items-center justify-center text-sm text-muted-foreground">
          <p>hello@humantodo.dev</p>
        </div>
      </footer>
    </TooltipProviderWrapper>
  </body>
</html>
